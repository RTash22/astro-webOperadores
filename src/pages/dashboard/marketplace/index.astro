---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { supabase } from '../../../db/supabase.js';

const { data: productos } = await supabase
  .from('catalogo_productos')
  .select(`
    id_producto, nombre_articulo, categoria, precio_mayorista, materiales, moq,
    descripcion, imagen_url,
    mayoristas ( id_mayorista, nombre_empresa, ubicacion, nivel_confianza ),
    ratings_productos ( calificacion, comentario )
  `)
  .order('nombre_articulo', { ascending: true });

const allProducts = (productos || []).map((p: any) => {
  const ratings = p.ratings_productos || [];
  const avg = ratings.length > 0 ? ratings.reduce((s: number, r: any) => s + r.calificacion, 0) / ratings.length : 0;
  return { ...p, _avgRating: Math.round(avg * 10) / 10, _totalReviews: ratings.length };
});

// Group by category
const categories: Record<string, any[]> = {};
for (const p of allProducts) {
  const cat = p.categoria || 'Otros';
  if (!categories[cat]) categories[cat] = [];
  categories[cat].push(p);
}
const categoryEntries = Object.entries(categories).sort((a, b) => b[1].length - a[1].length);

const catIcons: Record<string, string> = {
  'Periféricos': 'keyboard', 'Monitores': 'monitor', 'Audio': 'headphones',
  'Mobiliario': 'chair', 'Accesorios': 'cable', 'Computadoras': 'computer',
  'Redes': 'router', 'Almacenamiento': 'storage', 'Impresoras': 'print',
};
const catColors: Record<string, string> = {
  'Periféricos': 'from-blue-500/10 to-blue-600/5', 'Monitores': 'from-violet-500/10 to-violet-600/5',
  'Audio': 'from-rose-500/10 to-rose-600/5', 'Mobiliario': 'from-emerald-500/10 to-emerald-600/5',
  'Accesorios': 'from-amber-500/10 to-amber-600/5', 'Computadoras': 'from-cyan-500/10 to-cyan-600/5',
};

function renderStars(level: number): string {
  let html = '';
  for (let i = 0; i < 5; i++) html += i < Math.round(level) ? '<span class="text-amber-400 text-xs">★</span>' : '<span class="text-outline/30 text-xs">★</span>';
  return html;
}
---

<DashboardLayout title="Catálogo · Operadores">
  <div class="p-6 md:p-8 max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-outline mb-3">
        <a href="/dashboard" class="hover:text-primary transition-colors">Dashboard</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <span class="text-primary font-medium">Catálogo de Productos</span>
      </nav>
      <div class="flex items-end justify-between gap-4">
        <div>
          <h1 class="font-headline text-3xl font-extrabold text-on-surface tracking-tight">Catálogo de Proveedores</h1>
          <p class="text-on-surface-variant mt-1">Explora todos los productos disponibles de los mayoristas. {allProducts.length} productos en {categoryEntries.length} categorías.</p>
        </div>
        <div class="relative flex-shrink-0 w-80">
          <input type="text" id="catalog-search" placeholder="Buscar producto, proveedor, material..." class="w-full bg-surface-container-lowest border-none py-3 px-4 pl-10 rounded-xl text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:outline-none shadow-sm" />
          <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-lg">search</span>
        </div>
      </div>
    </div>

    <!-- Category quick nav -->
    <div class="flex gap-2 mb-8 overflow-x-auto pb-2 flex-wrap">
      {categoryEntries.map(([cat, items]) => (
        <a href={`#cat-${cat.toLowerCase().replace(/\s/g, '-')}`} class="flex items-center gap-2 px-4 py-2 rounded-xl bg-surface-container-lowest hover:bg-surface-container-low transition-colors text-sm font-medium text-on-surface-variant hover:text-on-surface whitespace-nowrap">
          <span class="material-symbols-outlined text-base text-primary">{catIcons[cat] || 'category'}</span>
          {cat}
          <span class="text-[10px] font-bold text-outline bg-outline/10 px-1.5 py-0.5 rounded-full">{items.length}</span>
        </a>
      ))}
    </div>

    <!-- Category sections -->
    <div class="space-y-10" id="catalog-sections">
      {categoryEntries.map(([cat, items]) => (
        <section id={`cat-${cat.toLowerCase().replace(/\s/g, '-')}`} class="catalog-section" data-category={cat.toLowerCase()}>
          <!-- Section header -->
          <div class={`rounded-2xl bg-gradient-to-r ${catColors[cat] || 'from-primary/10 to-primary/5'} p-6 mb-5`}>
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-xl bg-white/80 flex items-center justify-center shadow-sm">
                <span class="material-symbols-outlined text-primary text-2xl">{catIcons[cat] || 'category'}</span>
              </div>
              <div>
                <h2 class="font-headline text-xl font-extrabold text-on-surface">{cat}</h2>
                <p class="text-sm text-on-surface-variant">{items.length} producto{items.length > 1 ? 's' : ''} disponible{items.length > 1 ? 's' : ''}</p>
              </div>
            </div>
          </div>

          <!-- Products grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {items.map((p: any) => {
              const trust = p.mayoristas?.nivel_confianza || 0;
              const imgUrl = p.imagen_url;
              const desc = p.descripcion || p.materiales || '';
              const avg = p._avgRating;
              const reviews = p._totalReviews;
              return (
                <div class="product-card-catalog bg-surface-container-lowest rounded-xl overflow-hidden hover:shadow-lg hover:shadow-primary/5 transition-all group cursor-pointer border border-outline-variant/10 hover:border-primary/20"
                  data-name={p.nombre_articulo?.toLowerCase()}
                  data-materials={p.materiales?.toLowerCase()}
                  data-provider={p.mayoristas?.nombre_empresa?.toLowerCase()}
                  data-desc={p.descripcion?.toLowerCase()}
                >
                  <!-- Image -->
                  <div class="h-40 bg-surface-container-high overflow-hidden relative">
                    {imgUrl ? (
                      <img src={imgUrl} alt={p.nombre_articulo} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center">
                        <span class="material-symbols-outlined text-5xl text-outline/15">{catIcons[cat] || 'category'}</span>
                      </div>
                    )}
                    {reviews > 0 && (
                      <div class="absolute top-2 right-2 flex items-center gap-1 bg-black/60 backdrop-blur-sm text-white px-2 py-1 rounded-lg text-[10px] font-bold">
                        <span class="text-amber-400">★</span> {avg} ({reviews})
                      </div>
                    )}
                  </div>

                  <!-- Info -->
                  <div class="p-4">
                    <h3 class="font-bold text-on-surface text-sm mb-1">{p.nombre_articulo}</h3>
                    <p class="text-[11px] text-on-surface-variant line-clamp-2 mb-3 leading-relaxed">{desc || 'Sin descripción'}</p>
                    <div class="flex items-center justify-between">
                      <div>
                        <div class="flex items-center gap-1.5 mb-1">
                          <span class="text-[10px] text-outline flex items-center gap-0.5">
                            <span class="material-symbols-outlined text-[10px]">factory</span>
                            {p.mayoristas?.nombre_empresa || '—'}
                          </span>
                          <span class="flex items-center" set:html={renderStars(trust)}></span>
                        </div>
                        <p class="text-[10px] text-outline">MOQ: {p.moq || 1} uds · {p.materiales?.split(',')[0] || ''}</p>
                      </div>
                      <p class="font-headline text-xl font-extrabold text-primary">${p.precio_mayorista?.toFixed(2)}</p>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      ))}
    </div>

    <!-- Empty search state -->
    <div id="no-results" class="hidden text-center py-16 text-outline">
      <span class="material-symbols-outlined text-5xl block mb-3 opacity-20">search_off</span>
      <p class="text-lg font-semibold">Sin resultados</p>
      <p class="text-sm mt-1">Intenta con otro término de búsqueda.</p>
    </div>
  </div>

  <script>
    const searchInput = document.getElementById('catalog-search') as HTMLInputElement;
    const sections = document.querySelectorAll('.catalog-section');
    const cards = document.querySelectorAll('.product-card-catalog');
    const noResults = document.getElementById('no-results')!;

    searchInput?.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      let anyVisible = false;

      if (!q) {
        cards.forEach(c => (c as HTMLElement).style.display = '');
        sections.forEach(s => (s as HTMLElement).style.display = '');
        noResults.classList.add('hidden');
        return;
      }

      sections.forEach(section => {
        const sectionCards = section.querySelectorAll('.product-card-catalog');
        let sectionVisible = false;

        sectionCards.forEach(card => {
          const el = card as HTMLElement;
          const text = `${el.dataset.name} ${el.dataset.materials} ${el.dataset.provider} ${el.dataset.desc}`;
          const match = text.includes(q);
          el.style.display = match ? '' : 'none';
          if (match) { sectionVisible = true; anyVisible = true; }
        });

        (section as HTMLElement).style.display = sectionVisible ? '' : 'none';
      });

      noResults.classList.toggle('hidden', anyVisible);
    });
  </script>
</DashboardLayout>
