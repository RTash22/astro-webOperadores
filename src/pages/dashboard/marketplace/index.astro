---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';

const wholesalers = [
  {
    initial: 'T',
    name: 'TechNova Solutions',
    badge: 'Verified Wholesaler',
    badgeClass: 'text-secondary',
    price: '$84.50',
    minOrder: 'Min. 10 unidades',
    stock: '420 uds',
    stockClass: 'bg-secondary-container text-on-secondary-container',
    delivery: '24 - 48 hrs',
    deliveryNote: 'Nacional',
  },
  {
    initial: 'G',
    name: 'Global Import Co.',
    badge: 'Premium Partner',
    badgeClass: 'text-outline',
    price: '$82.10',
    minOrder: 'Min. 50 unidades',
    stock: '12 uds',
    stockClass: 'bg-error-container text-on-error-container',
    delivery: '5 - 7 días',
    deliveryNote: 'Importación',
  },
  {
    initial: 'N',
    name: 'Nexus Logistics',
    badge: 'Direct Factory',
    badgeClass: 'text-secondary',
    price: '$88.00',
    minOrder: 'Sin mínimo',
    stock: '>1000 uds',
    stockClass: 'bg-secondary-container text-on-secondary-container',
    delivery: 'Inmediata',
    deliveryNote: 'Pick-up disponible',
  },
];

const relatedProducts = [
  {
    name: 'Mouse Ergonómico MX',
    description: 'Precision Tracking',
    price: '$45.00',
    imgSrc: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCtpzPY0acyRggJtLlNMwBW8JfjjFkacgXk8uWCoVcy_pJxqBa8oPzxUwexQQU8EK28vciPeEcSrLfgtNdCKe4TgP89hIKAkrjd3gr5kCVqH5MqPxtGcYb5__hEaK5k-CeF-fnBRa1ZWn4dTkxD18wb0HXZ1-BTD7cg4l-KHguiFaODaeurTeu34WRwHoF0aUjO-9o2EmC5e-boHreV3bCGxRz8F-fZ16UOQo4OlBMwcbNWNau2Qjkjsf5sfazQdaI3U6mevuM8',
    imgAlt: 'Mouse Ergonómico',
    wide: true,
  },
  {
    name: 'Tablet Grafic Pro',
    description: null,
    price: '$120.00',
    imgSrc: 'https://lh3.googleusercontent.com/aida-public/AB6AXuCfETc9_I-54XGgzP6pPWleBjoe7Q4JLsIICQqLbRkD7WEDqM4Iuy1jPMLlc0FO01jUIZwEsCglRzF9fcrcXbgngzWVRz4NwsYyDX8XI_eqQB4i19zz0FfG8cLYBxigv73o_-kJenf2CrSLgrxyoXykZ1498cPV0yx4vlGayQkNclJNilGYLxCvBnSkdWLwgym38Sdt7aso9Tp7IZXTLHqNryXrMZUXGrRfWYsoO3X3HKN7z_c-SubOeeWMYye-2Le6BLKWiwzNuBU',
    imgAlt: 'Tablet',
    wide: false,
  },
  {
    name: 'Headset Studio',
    description: null,
    price: '$65.90',
    imgSrc: 'https://lh3.googleusercontent.com/aida-public/AB6AXuAaEbkCdG4Qz15UYml0NP-6TnHSUBguMtjqERFuIQ4akNgOZitdV6rLGz3I_4CRC2XkYfLEfpfU89TJJfqoMjXnL7vreubc8mWeHp6erFNJA5t4SLrPa1br4XYt3kTZnSx5DCWZwXHAo0aLU9C8l4huQJQzvQmyPZHyFrgq7UZlig3lT4LocClX-IU4ghpGaX5R2gX6SfVUy3eiArpU3nO5lldsCgpfo0DrkZOIVqXsAP63y_cS7-o1za0vKuUNhi7wlx6469qJsu8',
    imgAlt: 'Headset',
    wide: false,
  },
