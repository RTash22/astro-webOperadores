---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { supabase } from '../../../db/supabase.js';

const { data: solicitudes } = await supabase
  .from('solicitudes_cotizacion')
  .select(`
    id_solicitud, id_cliente, descripcion_articulo, especificaciones_req,
    nivel_urgencia, estado_solicitud, created_at, updated_at,
    clientes ( id_cliente, nombre_empresa, correo_contacto, telefono_contacto )
  `)
  .order('created_at', { ascending: false });

const allSolicitudes = solicitudes || [];

const { data: productos } = await supabase
  .from('catalogo_productos')
  .select(`
    id_producto, nombre_articulo, categoria, precio_mayorista, materiales, moq,
    descripcion, imagen_url,
    mayoristas ( id_mayorista, nombre_empresa, ubicacion, nivel_confianza ),
    ratings_productos ( calificacion, comentario )
  `)
  .order('nombre_articulo', { ascending: true });

// Compute average rating per product
const allProducts = (productos || []).map((p: any) => {
  const ratings = p.ratings_productos || [];
  const avgRating = ratings.length > 0
    ? ratings.reduce((sum: number, r: any) => sum + r.calificacion, 0) / ratings.length
    : 0;
  const totalReviews = ratings.length;
  return { ...p, _avgRating: Math.round(avgRating * 10) / 10, _totalReviews: totalReviews };
});

const total = allSolicitudes.length;
const pendientes = allSolicitudes.filter((s: any) => s.estado_solicitud?.toLowerCase() === 'pendiente').length;
const enProceso = allSolicitudes.filter((s: any) => ['atendida', 'en proceso'].includes(s.estado_solicitud?.toLowerCase())).length;
const completadas = allSolicitudes.filter((s: any) => s.estado_solicitud?.toLowerCase() === 'completada').length;

function formatDate(dateStr: string) {
  if (!dateStr) return '—';
  return new Date(dateStr).toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

// Category icons map
const catIcons: Record<string, string> = {
  'periféricos': 'keyboard', 'monitores': 'monitor', 'audio': 'headphones',
  'mobiliario': 'chair', 'accesorios': 'cable', 'computadoras': 'computer',
  'redes': 'router', 'almacenamiento': 'storage', 'impresoras': 'print',
};
---

<DashboardLayout title="Solicitudes · Operadores">
  <div class="p-6 h-[calc(100vh-64px)] flex flex-col overflow-hidden">

    <!-- Header -->
    <div class="mb-4 flex-shrink-0">
      <nav class="flex items-center gap-2 text-sm text-outline mb-2">
        <a href="/dashboard" class="hover:text-primary transition-colors">Dashboard</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <span class="text-primary font-medium">Solicitudes</span>
      </nav>
      <div class="flex items-center justify-between">
        <div>
          <h1 class="font-headline text-2xl font-extrabold text-on-surface tracking-tight">Solicitudes de Clientes</h1>
          <p class="text-on-surface-variant text-sm mt-0.5">Selecciona, revisa productos sugeridos y arma la cotización.</p>
        </div>
        <div class="flex gap-3">
          <div class="flex items-center gap-2 bg-error/10 text-error px-3 py-1.5 rounded-full text-xs font-bold">
            <span class="material-symbols-outlined text-sm">pending</span>
            <span id="stat-pendientes">{pendientes}</span> pendientes
          </div>
          <div class="flex items-center gap-2 bg-secondary/10 text-secondary px-3 py-1.5 rounded-full text-xs font-bold">
            <span class="material-symbols-outlined text-sm">autorenew</span>
            <span id="stat-proceso">{enProceso}</span> en proceso
          </div>
          <div class="flex items-center gap-2 bg-outline/10 text-outline px-3 py-1.5 rounded-full text-xs font-bold">
            <span class="material-symbols-outlined text-sm">check_circle</span>
            {completadas} completadas
          </div>
        </div>
      </div>
    </div>

    <!-- Split Panel -->
    <div class="flex-1 flex gap-4 min-h-0 overflow-hidden">

      <!-- LEFT: Solicitudes List -->
      <div class="w-[360px] flex-shrink-0 flex flex-col bg-surface-container-lowest rounded-xl overflow-hidden">
        <div class="px-4 py-3 border-b border-outline-variant/10 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-sm">inbox</span>
          <span class="text-sm font-bold text-on-surface">{total} Solicitudes</span>
        </div>
        <div class="flex-1 overflow-y-auto divide-y divide-outline-variant/5" id="solicitudes-list">
          {allSolicitudes.map((sol: any, idx: number) => {
            const urgencyColor = sol.nivel_urgencia?.toLowerCase() === 'alta' ? 'bg-error' : sol.nivel_urgencia?.toLowerCase() === 'media' ? 'bg-tertiary' : 'bg-outline';
            const statusColor = sol.estado_solicitud?.toLowerCase() === 'pendiente' ? 'text-error' : sol.estado_solicitud?.toLowerCase() === 'completada' ? 'text-outline' : 'text-secondary';
            return (
              <button
                class="solicitud-item w-full text-left px-4 py-4 hover:bg-surface-container-low/70 transition-all cursor-pointer relative"
                data-index={idx}
                data-id={sol.id_solicitud}
                data-client={sol.clientes?.nombre_empresa || 'Sin empresa'}
                data-email={sol.clientes?.correo_contacto || ''}
                data-phone={sol.clientes?.telefono_contacto || ''}
                data-desc={sol.descripcion_articulo || ''}
                data-specs={JSON.stringify(sol.especificaciones_req || {})}
                data-urgency={sol.nivel_urgencia || ''}
                data-status={sol.estado_solicitud || ''}
                data-date={formatDate(sol.created_at)}
              >
                <div class={`absolute left-0 top-0 bottom-0 w-1 ${urgencyColor} rounded-r opacity-60`}></div>
                <div class="pl-2">
                  <div class="flex items-center justify-between mb-1">
                    <div class="flex items-center gap-2">
                      <div class="w-7 h-7 rounded-full flex items-center justify-center font-bold text-[10px] bg-primary-fixed text-on-primary-fixed">
                        {(sol.clientes?.nombre_empresa || '?')[0].toUpperCase()}
                      </div>
                      <span class="text-sm font-bold text-on-surface">{sol.clientes?.nombre_empresa || 'Sin empresa'}</span>
                    </div>
                    <span class={`sol-status-label text-[10px] font-bold uppercase ${statusColor}`} data-sol-id={sol.id_solicitud}>{sol.estado_solicitud}</span>
                  </div>
                  <p class="text-xs text-on-surface-variant line-clamp-2 mb-1.5 leading-relaxed">{sol.descripcion_articulo || '—'}</p>
                  <div class="flex items-center justify-between">
                    <span class={`text-[10px] font-bold uppercase tracking-wider ${sol.nivel_urgencia?.toLowerCase() === 'alta' ? 'text-error' : sol.nivel_urgencia?.toLowerCase() === 'media' ? 'text-tertiary' : 'text-outline'}`}>● {sol.nivel_urgencia || '—'}</span>
                    <span class="text-[10px] text-outline">{formatDate(sol.created_at)}</span>
                  </div>
                </div>
              </button>
            );
          })}
        </div>
      </div>

      <!-- RIGHT -->
      <div class="flex-1 flex flex-col min-h-0 overflow-hidden gap-4">

        <div id="empty-state" class="flex-1 bg-surface-container-lowest rounded-xl flex items-center justify-center">
          <div class="text-center text-outline">
            <span class="material-symbols-outlined text-6xl block mb-3 opacity-15">touch_app</span>
            <p class="text-lg font-semibold">Selecciona una solicitud</p>
            <p class="text-sm mt-1">Haz clic en una solicitud para ver detalles y armar la cotización.</p>
          </div>
        </div>

        <div id="detail-panel" class="flex-1 flex flex-col min-h-0 overflow-hidden gap-4" style="display: none;">

          <!-- TOP: Solicitud Detail -->
          <div class="bg-surface-container-lowest rounded-xl p-5 flex-shrink-0">
            <div class="flex items-start justify-between mb-3">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm bg-primary-fixed text-on-primary-fixed" id="detail-avatar">?</div>
                <div>
                  <h3 class="font-bold text-on-surface text-lg" id="detail-client">—</h3>
                  <p class="text-xs text-outline" id="detail-email">—</p>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <a id="detail-sms-btn" href="#" class="inline-flex items-center gap-1 px-3 py-2 rounded-lg bg-secondary/10 text-secondary text-xs font-bold hover:bg-secondary/20 transition-colors">
                  <span class="material-symbols-outlined text-sm">sms</span> SMS
                </a>
                <span id="detail-urgency-badge" class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider">—</span>
                <span id="detail-status-badge" class="px-3 py-1.5 rounded-full text-xs font-bold inline-flex items-center gap-1">—</span>
              </div>
            </div>
            <div class="bg-surface-container-low rounded-xl p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="material-symbols-outlined text-primary text-sm">description</span>
                <span class="text-xs font-bold uppercase tracking-wider text-outline">Lo que solicita el cliente</span>
              </div>
              <p class="text-sm text-on-surface font-medium leading-relaxed" id="detail-desc">—</p>
              <div id="detail-specs-container" class="mt-3 pt-3 border-t border-outline-variant/10" style="display: none;">
                <span class="text-[10px] font-bold uppercase tracking-wider text-outline block mb-2">Especificaciones</span>
                <div id="detail-specs" class="flex flex-wrap gap-2"></div>
              </div>
            </div>
          </div>

          <!-- BOTTOM: Products + Cart -->
          <div class="flex-1 flex gap-4 min-h-0 overflow-hidden">

            <!-- Products -->
            <div class="flex-1 bg-surface-container-lowest rounded-xl flex flex-col min-h-0 overflow-hidden">
              <div class="px-4 py-3 border-b border-outline-variant/10 flex items-center justify-between flex-shrink-0 flex-wrap gap-2">
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-secondary text-sm">auto_awesome</span>
                  <span class="text-sm font-bold text-on-surface" id="products-title">Productos Sugeridos</span>
                </div>
                <div class="flex items-center gap-1.5">
                  <button id="btn-show-suggested" class="mode-btn text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-lg bg-secondary/20 text-secondary">Sugeridos</button>
                  <button id="btn-show-all" class="mode-btn text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-lg bg-outline/10 text-outline hover:bg-outline/20 transition-colors">Todos</button>
                  <span class="w-px h-4 bg-outline-variant/20 mx-1"></span>
                  <button id="btn-sort-rating" class="sort-btn text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-lg bg-outline/10 text-outline hover:bg-outline/20 transition-colors" title="Ordenar por mejor proveedor">⭐ Rating</button>
                  <button id="btn-sort-price" class="sort-btn text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-lg bg-outline/10 text-outline hover:bg-outline/20 transition-colors" title="Ordenar por menor precio">💲 Precio</button>
                </div>
              </div>
              <div class="px-4 py-2 flex-shrink-0">
                <div class="relative">
                  <input type="text" id="product-search" placeholder="Buscar producto por nombre, categoría, material..." class="w-full bg-surface-container-low border-none py-2.5 px-4 pl-9 rounded-xl text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:outline-none" />
                  <span class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-outline text-base">search</span>
                </div>
              </div>
              <div class="flex-1 overflow-y-auto px-4 pb-3 space-y-2" id="products-container"></div>
            </div>

            <!-- Cart -->
            <div class="w-[340px] flex-shrink-0 bg-surface-container-lowest rounded-xl flex flex-col min-h-0 overflow-hidden">
              <div class="px-4 py-3 border-b border-outline-variant/10 flex items-center justify-between flex-shrink-0">
                <div class="flex items-center gap-2">
                  <span class="material-symbols-outlined text-primary text-sm">shopping_cart</span>
                  <span class="text-sm font-bold text-on-surface">Cotización</span>
                </div>
                <span id="cart-count" class="text-xs font-bold text-outline bg-outline/10 px-2 py-0.5 rounded-full">0</span>
              </div>
              <div class="flex-1 overflow-y-auto px-3 py-3 space-y-2" id="cart-container">
                <div id="cart-empty" class="text-center text-outline py-8">
                  <span class="material-symbols-outlined text-3xl block mb-2 opacity-20">add_shopping_cart</span>
                  <p class="text-xs">Agrega productos del catálogo</p>
                </div>
              </div>
              <!-- Footer: total + finalize -->
              <div class="px-4 py-3 border-t border-outline-variant/10 flex-shrink-0 bg-surface-container-low space-y-3">
                <div class="flex justify-between items-center">
                  <span class="text-xs text-outline font-bold uppercase tracking-wider">Total estimado</span>
                  <p class="font-headline text-xl font-extrabold text-primary" id="cart-total">$0.00</p>
                </div>
                <!-- Notes + Finalize (hidden until cart has items) -->
                <div id="cart-finalize-section" style="display: none;">
                  <textarea id="cart-notes" rows="2" placeholder="Notas para los proveedores (opcional)..." class="w-full bg-surface-container-highest border-none rounded-lg py-2 px-3 text-xs text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:outline-none resize-none mb-2"></textarea>
                  <button id="btn-finalize" onclick="finalizeCotizacion()" class="w-full py-3 rounded-xl text-sm font-bold bg-gradient-to-br from-secondary to-secondary-container text-white hover:opacity-95 transition-all active:scale-[0.98] flex items-center justify-center gap-2 shadow-lg shadow-secondary/20">
                    <span class="material-symbols-outlined text-base">send</span>
                    Terminar Cotización
                  </button>
                  <p class="text-[10px] text-outline mt-1.5 text-center leading-relaxed">Se enviará a los proveedores y se notificará al cliente.</p>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Product Detail Modal -->
  <div id="product-modal" class="fixed inset-0 z-[100] flex items-center justify-center p-6" style="display: none;">
    <!-- Overlay -->
    <div id="modal-overlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <!-- Modal Content -->
    <div class="relative bg-surface-container-lowest rounded-2xl shadow-2xl max-w-2xl w-full max-h-[85vh] overflow-hidden flex flex-col animate-[modalIn_0.2s_ease-out]">
      <!-- Close -->
      <button id="modal-close" class="absolute top-4 right-4 z-10 w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center text-outline hover:text-on-surface hover:bg-surface-container-high transition-all">
        <span class="material-symbols-outlined text-lg">close</span>
      </button>

      <!-- Image -->
      <div class="relative h-56 bg-surface-container-high flex-shrink-0 overflow-hidden">
        <img id="modal-img" src="" alt="" class="w-full h-full object-cover" />
        <div id="modal-img-fallback" class="absolute inset-0 flex items-center justify-center" style="display: none;">
          <span class="material-symbols-outlined text-6xl text-outline/20" id="modal-icon">category</span>
        </div>
        <!-- Badges overlay -->
        <div class="absolute bottom-3 left-3 flex gap-2">
          <span id="modal-category" class="px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider bg-black/60 text-white backdrop-blur-sm"></span>
        </div>
      </div>

      <!-- Scrollable content -->
      <div class="flex-1 overflow-y-auto p-6 space-y-5">

        <!-- Title row -->
        <div class="flex items-start justify-between gap-4">
          <div>
            <h2 class="font-headline text-xl font-extrabold text-on-surface" id="modal-name">—</h2>
            <div class="flex items-center gap-3 mt-1">
              <span class="text-sm text-outline flex items-center gap-1" id="modal-provider">
                <span class="material-symbols-outlined text-sm">factory</span> —
              </span>
              <span class="flex items-center gap-0.5" id="modal-trust-stars"></span>
            </div>
          </div>
          <div class="text-right flex-shrink-0">
            <p class="font-headline text-3xl font-extrabold text-primary" id="modal-price">$0</p>
            <p class="text-xs text-outline" id="modal-moq">MOQ: —</p>
          </div>
        </div>

        <!-- Description -->
        <div class="bg-surface-container-low rounded-xl p-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="material-symbols-outlined text-primary text-sm">info</span>
            <span class="text-xs font-bold uppercase tracking-wider text-outline">Descripción del producto</span>
          </div>
          <p class="text-sm text-on-surface leading-relaxed" id="modal-desc">—</p>
        </div>

        <!-- Materials -->
        <div id="modal-materials-section">
          <div class="flex items-center gap-2 mb-2">
            <span class="material-symbols-outlined text-tertiary text-sm">science</span>
            <span class="text-xs font-bold uppercase tracking-wider text-outline">Materiales</span>
          </div>
          <p class="text-sm text-on-surface-variant" id="modal-materials">—</p>
        </div>

        <!-- Client ratings -->
        <div id="modal-ratings-section">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-amber-500 text-sm">star</span>
            <span class="text-xs font-bold uppercase tracking-wider text-outline">Reseñas de clientes</span>
            <span id="modal-avg-badge" class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-500/10 text-amber-700"></span>
          </div>
          <div id="modal-reviews" class="space-y-2"></div>
        </div>
      </div>

      <!-- Footer: Add to cart -->
      <div class="px-6 py-4 border-t border-outline-variant/10 bg-surface-container-low flex items-center justify-between gap-4 flex-shrink-0">
        <div class="flex items-center gap-2">
          <div class="flex items-center bg-surface-container-highest rounded-lg overflow-hidden">
            <button onclick="changeQtyModal(-1)" class="px-2 py-1.5 text-outline hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">remove</span></button>
            <input type="number" id="modal-qty" value="1" min="1" class="w-12 text-center text-sm font-bold bg-transparent border-none focus:ring-0 text-on-surface" />
            <button onclick="changeQtyModal(1)" class="px-2 py-1.5 text-outline hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">add</span></button>
          </div>
          <span class="text-xs text-outline" id="modal-subtotal">= $0.00</span>
        </div>
        <div class="flex items-center gap-3">
          <button id="modal-remove-btn" onclick="modalRemoveFromCart()" class="px-5 py-3 rounded-xl text-sm font-bold bg-error/10 text-error hover:bg-error/20 transition-all flex items-center gap-2" style="display: none;">
            <span class="material-symbols-outlined text-base">remove_shopping_cart</span> Quitar
          </button>
          <button id="modal-add-btn" onclick="modalAddToCart()" class="px-5 py-3 rounded-xl text-sm font-bold bg-gradient-to-br from-primary to-primary-container text-white hover:scale-105 transition-all active:scale-95 flex items-center gap-2 shadow-lg shadow-primary/20">
            <span class="material-symbols-outlined text-base">add_shopping_cart</span> Agregar a Cotización
          </button>
        </div>
      </div>
    </div>
  </div>

  <style>
    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.95) translateY(10px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }
  </style>

  <script define:vars={{ allProducts: JSON.stringify(allProducts), catIcons: JSON.stringify(catIcons) }}>
    window.__PRODUCTS__ = JSON.parse(allProducts);
    window.__CAT_ICONS__ = JSON.parse(catIcons);
  </script>

  <script>
    const products = (window as any).__PRODUCTS__ as any[];
    const catIcons = (window as any).__CAT_ICONS__ as Record<string, string>;
    let currentSolicitudId: string | null = null;
    let showMode: 'suggested' | 'all' = 'suggested';
    let sortMode: 'relevance' | 'rating' | 'price' = 'relevance';
    let currentDescription = '';
    let currentSpecs: Record<string, any> = {};
    let cartProductIds = new Set<string>();

    // ── Stars helper ──
    function renderStars(level: number): string {
      const max = 5;
      const filled = Math.min(Math.max(Math.round(level || 0), 0), max);
      let html = '';
      for (let i = 0; i < max; i++) {
        html += i < filled
          ? '<span class="text-amber-400 text-xs">★</span>'
          : '<span class="text-outline/30 text-xs">★</span>';
      }
      return html;
    }

    // ── Keywords ──
    function extractKeywords(text: string): string[] {
      const stop = new Set(['de','para','con','sin','que','los','las','del','una','uno','unos','unas','el','la','en','por','y','o','a','al','es','su','muy','más','se','no','me','mi','necesito','busco','quiero','cotización','unidades','nueva','nuevo','nuevos','nuevas','pulgadas']);
      return text.toLowerCase().replace(/[^a-záéíóúñü0-9\s]/g, '').split(/\s+/).filter(w => w.length > 2 && !stop.has(w));
    }

    function scoreProduct(product: any, desc: string, specs: Record<string, any>): number {
      const keywords = extractKeywords(desc);
      const specKeywords = Object.values(specs).flatMap(v => extractKeywords(String(v)));
      const all = [...keywords, ...specKeywords];
      if (all.length === 0) return 0;
      const name = (product.nombre_articulo || '').toLowerCase();
      const cat = (product.categoria || '').toLowerCase();
      const mat = (product.materiales || '').toLowerCase();
      let score = 0;
      for (const kw of all) {
        if (name.includes(kw)) score += 3;
        else if (cat.includes(kw)) score += 2;
        else if (mat.includes(kw)) score += 1;
      }
      return score;
    }

    function getScoredProducts(): any[] {
      return products.map(p => ({ ...p, _score: scoreProduct(p, currentDescription, currentSpecs) }));
    }

    // ── Render products ──
    function renderProducts() {
      const container = document.getElementById('products-container')!;
      const searchInput = document.getElementById('product-search') as HTMLInputElement;
      const titleEl = document.getElementById('products-title')!;
      const q = searchInput?.value.toLowerCase().trim() || '';

      let list = getScoredProducts();

      if (showMode === 'suggested') {
        list = list.filter(p => p._score > 0);
        titleEl.textContent = `Sugeridos (${list.length})`;
      } else {
        titleEl.textContent = `Todos (${list.length})`;
      }

      if (q) {
        list = list.filter(p => `${p.nombre_articulo} ${p.categoria} ${p.materiales} ${p.mayoristas?.nombre_empresa}`.toLowerCase().includes(q));
      }

      // Sort
      if (sortMode === 'rating') {
        list.sort((a, b) => (b._avgRating || 0) - (a._avgRating || 0) || (b.mayoristas?.nivel_confianza || 0) - (a.mayoristas?.nivel_confianza || 0));
      } else if (sortMode === 'price') {
        list.sort((a, b) => (a.precio_mayorista || 0) - (b.precio_mayorista || 0));
      } else {
        list.sort((a, b) => b._score - a._score);
      }

      if (list.length === 0) {
        container.innerHTML = `<div class="text-center text-outline py-8"><span class="material-symbols-outlined text-3xl block mb-2 opacity-20">search_off</span><p class="text-xs">${showMode === 'suggested' ? 'No hay productos relacionados. Prueba "Todos" o busca manualmente.' : 'Sin resultados.'}</p></div>`;
        return;
      }

      container.innerHTML = list.map(p => {
        const trust = p.mayoristas?.nivel_confianza || 0;
        const inCart = cartProductIds.has(p.id_producto);
        const icon = catIcons[(p.categoria || '').toLowerCase()] || 'category';
        const scoreTag = showMode === 'suggested' && p._score ? `<span class="px-1.5 py-0.5 rounded text-[9px] font-bold bg-secondary/10 text-secondary">${p._score} pts</span>` : '';
        const moqNum = p.moq || 1;
        const imgUrl = p.imagen_url;
        const desc = p.descripcion || p.materiales || 'Sin descripción';
        const avgRating = p._avgRating || 0;
        const totalReviews = p._totalReviews || 0;
        const prodIdx = products.findIndex(x => x.id_producto === p.id_producto);

        return `
          <div class="product-card rounded-xl p-4 transition-all ${inCart ? 'bg-primary/5 ring-1 ring-primary/20' : 'bg-surface-container-low hover:bg-surface-bright'} group cursor-pointer" data-prod-idx="${prodIdx}">
            <div class="flex gap-3">
              <!-- Image or Icon -->
              ${imgUrl
                ? `<img src="${imgUrl}" alt="${p.nombre_articulo}" class="w-16 h-16 rounded-xl object-cover flex-shrink-0" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                   <div class="w-16 h-16 rounded-xl bg-surface-container-highest items-center justify-center flex-shrink-0" style="display:none"><span class="material-symbols-outlined text-primary">${icon}</span></div>`
                : `<div class="w-16 h-16 rounded-xl bg-surface-container-highest flex items-center justify-center flex-shrink-0"><span class="material-symbols-outlined text-primary">${icon}</span></div>`
              }
              <!-- Info -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                  <h4 class="font-bold text-on-surface text-sm">${p.nombre_articulo || '—'}</h4>
                  <span class="px-1.5 py-0.5 rounded text-[9px] font-bold uppercase bg-surface-container-highest text-on-surface-variant">${p.categoria || '—'}</span>
                  ${scoreTag}
                </div>
                <!-- Description -->
                <p class="text-[11px] text-on-surface-variant leading-relaxed mb-1.5 line-clamp-2">${desc}</p>
                <!-- Provider + stars + client rating -->
                <div class="flex items-center gap-3 flex-wrap">
                  <span class="text-[11px] text-outline flex items-center gap-1">
                    <span class="material-symbols-outlined text-xs">factory</span>
                    ${p.mayoristas?.nombre_empresa || '—'}
                  </span>
                  <span class="flex items-center gap-0.5" title="Confianza proveedor: ${trust}/5">
                    ${renderStars(trust)}
                  </span>
                  ${totalReviews > 0
                    ? `<span class="text-[10px] flex items-center gap-1 bg-amber-500/10 text-amber-700 px-1.5 py-0.5 rounded-full font-semibold" title="Calificación de clientes">
                        <span class="material-symbols-outlined text-xs">groups</span>
                        ${avgRating}★ (${totalReviews})
                      </span>`
                    : `<span class="text-[10px] text-outline">Sin reseñas</span>`
                  }
                </div>
              </div>
              <!-- Price + action -->
              <div class="flex flex-col items-end justify-between flex-shrink-0 gap-2">
                <div class="text-right">
                  <p class="text-lg font-bold text-primary">$${(p.precio_mayorista || 0).toFixed(2)}</p>
                  <p class="text-[10px] text-outline">MOQ: ${moqNum} uds</p>
                </div>
                ${inCart
                  ? `<button data-action="remove" data-product-id="${p.id_producto}" class="px-3 py-2 rounded-xl text-xs font-bold bg-error/10 text-error hover:bg-error/20 transition-all flex items-center gap-1">
                      <span class="material-symbols-outlined text-sm">remove_shopping_cart</span> Quitar
                    </button>`
                  : `<div class="flex items-center gap-1.5">
                      <div class="flex items-center bg-surface-container-highest rounded-lg overflow-hidden">
                        <button data-action="qty-down" class="px-1.5 py-1 text-outline hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">remove</span></button>
                        <input type="number" value="${moqNum}" min="1" class="qty-input w-10 text-center text-sm font-bold bg-transparent border-none focus:ring-0 text-on-surface" data-action="qty-input" />
                        <button data-action="qty-up" class="px-1.5 py-1 text-outline hover:text-primary transition-colors"><span class="material-symbols-outlined text-sm">add</span></button>
                      </div>
                      <button data-action="add" data-product-id="${p.id_producto}" data-price="${p.precio_mayorista || 0}" class="px-3 py-2 rounded-xl text-xs font-bold bg-gradient-to-br from-primary to-primary-container text-white hover:scale-105 transition-all active:scale-95 flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">add_shopping_cart</span> Agregar
                      </button>
                    </div>`
                }
              </div>
            </div>
          </div>`;
      }).join('');

      // Attach event delegation on the products container
      attachProductsListeners();
    }

    // Event delegation for product cards — no more inline onclick conflicts
    function attachProductsListeners() {
      const container = document.getElementById('products-container');
      if (!container) return;

      // Remove old listener by cloning
      const newContainer = container.cloneNode(true) as HTMLElement;
      container.parentNode?.replaceChild(newContainer, container);

      newContainer.addEventListener('click', async (e) => {
        const target = e.target as HTMLElement;

        // Find closest element with data-action
        const actionEl = target.closest('[data-action]') as HTMLElement;

        if (actionEl) {
          const action = actionEl.dataset.action;

          if (action === 'add') {
            const productId = actionEl.dataset.productId!;
            const price = parseFloat(actionEl.dataset.price || '0');
            const qtyInput = actionEl.closest('.flex')?.querySelector('.qty-input') as HTMLInputElement;
            const qty = parseInt(qtyInput?.value || '1');

            if (cartProductIds.has(productId)) return; // Already in cart

            const totalPrice = price * qty * 1.15;
            actionEl.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">progress_activity</span>';
            (actionEl as any).disabled = true;

            try {
              const res = await fetch('/api/cotizaciones', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id_solicitud: currentSolicitudId, id_producto: productId, precio_final_cliente: totalPrice, costo_envio: 0, cantidad: qty }),
              });
              const json = await res.json();
              if (!res.ok) { alert(json.error || 'Error'); renderProducts(); return; }
              updateSolicitudStatus(currentSolicitudId!, 'en proceso');
              await loadCart();
            } catch (err) { alert('Error de conexión'); renderProducts(); }
            return;
          }

          if (action === 'remove') {
            const productId = actionEl.dataset.productId!;
            const res = await fetch(`/api/cotizaciones?id_solicitud=${currentSolicitudId}`);
            const json = await res.json();
            const item = (json.data || []).find((i: any) => i.id_producto === productId);
            if (item) {
              const delRes = await fetch(`/api/cotizaciones?id_cotizacion=${item.id_cotizacion}`, { method: 'DELETE' });
              if (delRes.ok) {
                await loadCart();
                if (cartProductIds.size === 0) updateSolicitudStatus(currentSolicitudId!, 'pendiente');
              }
            }
            return;
          }

          if (action === 'qty-down') {
            const input = actionEl.parentElement?.querySelector('.qty-input') as HTMLInputElement;
            if (input) input.value = String(Math.max(1, parseInt(input.value || '1') - 1));
            return;
          }

          if (action === 'qty-up') {
            const input = actionEl.parentElement?.querySelector('.qty-input') as HTMLInputElement;
            if (input) input.value = String(parseInt(input.value || '1') + 1);
            return;
          }

          if (action === 'qty-input') return; // Just clicking the input, do nothing
        }

        // No action found → open modal (clicked on card body)
        const card = target.closest('[data-prod-idx]') as HTMLElement;
        if (card) {
          const idx = parseInt(card.dataset.prodIdx || '-1');
          if (idx >= 0) (window as any).openProductModal(idx);
        }
      });
    }

    // ── Cart ──
    async function loadCart() {
      if (!currentSolicitudId) return;
      const res = await fetch(`/api/cotizaciones?id_solicitud=${currentSolicitudId}`);
      const json = await res.json();
      const items = json.data || [];
      cartProductIds = new Set(items.map((i: any) => i.id_producto));
      const container = document.getElementById('cart-container')!;
      const countEl = document.getElementById('cart-count')!;
      const totalEl = document.getElementById('cart-total')!;
      const finalizeSection = document.getElementById('cart-finalize-section')!;
      countEl.textContent = String(items.length);

      // Check if this cotización was already finalized
      const isFinalized = items.length > 0 && items[0].estado === 'enviada';

      if (items.length === 0) {
        container.innerHTML = `<div class="text-center text-outline py-8"><span class="material-symbols-outlined text-3xl block mb-2 opacity-20">add_shopping_cart</span><p class="text-xs">Agrega productos del catálogo</p></div>`;
        totalEl.textContent = '$0.00';
        finalizeSection.style.display = 'none';
      } else {
        let total = 0;
        let totalUnits = 0;
        container.innerHTML = items.map((item: any) => {
          const prod = item.catalogo_productos;
          const price = item.precio_final_cliente || 0;
          const qty = item.cantidad || 1;
          const unitPrice = qty > 0 ? price / qty : price;
          const trust = prod?.mayoristas?.nivel_confianza || 0;
          const imgUrl = prod?.imagen_url;
          total += price;
          totalUnits += qty;
          return `
            <div class="bg-surface-container-low rounded-xl p-3 group relative ${isFinalized ? 'opacity-80' : ''}">
              ${!isFinalized ? `<button onclick="removeFromCart('${item.id_cotizacion}')" class="absolute top-2 right-2 p-1 rounded-lg hover:bg-error/10 text-outline hover:text-error transition-all opacity-0 group-hover:opacity-100" title="Quitar">
                <span class="material-symbols-outlined text-sm">close</span>
              </button>` : ''}
              <div class="flex gap-2.5">
                ${imgUrl
                  ? `<img src="${imgUrl}" alt="" class="w-10 h-10 rounded-lg object-cover flex-shrink-0" />`
                  : `<div class="w-10 h-10 rounded-lg bg-surface-container-highest flex items-center justify-center flex-shrink-0"><span class="material-symbols-outlined text-primary text-sm">inventory_2</span></div>`
                }
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-bold text-on-surface truncate pr-5">${prod?.nombre_articulo || '—'}</p>
                  <p class="text-[10px] text-outline">${prod?.mayoristas?.nombre_empresa || '—'}</p>
                  <div class="flex items-center justify-between mt-1.5">
                    <span class="text-[10px] text-on-surface-variant">
                      <span class="font-bold text-on-surface">${qty}</span> uds × $${unitPrice.toFixed(2)}
                    </span>
                    <span class="text-sm font-bold text-primary">$${price.toFixed(2)}</span>
                  </div>
                </div>
              </div>
            </div>`;
        }).join('');
        totalEl.textContent = '$' + total.toLocaleString('en-US', { minimumFractionDigits: 2 });

        // Show finalize section only if not yet finalized
        if (isFinalized) {
          finalizeSection.innerHTML = `
            <div class="bg-secondary/10 rounded-xl p-3 text-center">
              <span class="material-symbols-outlined text-secondary text-lg block mb-1">check_circle</span>
              <p class="text-xs font-bold text-secondary">Cotización enviada</p>
              <p class="text-[10px] text-outline mt-1">Esperando respuesta de proveedores</p>
            </div>`;
          finalizeSection.style.display = 'block';
        } else {
          finalizeSection.innerHTML = `
            <textarea id="cart-notes" rows="2" placeholder="Notas para los proveedores (opcional)..." class="w-full bg-surface-container-highest border-none rounded-lg py-2 px-3 text-xs text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:outline-none resize-none mb-2"></textarea>
            <button id="btn-finalize" onclick="finalizeCotizacion()" class="w-full py-3 rounded-xl text-sm font-bold bg-gradient-to-br from-secondary to-secondary-container text-white hover:opacity-95 transition-all active:scale-[0.98] flex items-center justify-center gap-2 shadow-lg shadow-secondary/20">
              <span class="material-symbols-outlined text-base">send</span>
              Terminar Cotización
            </button>
            <p class="text-[10px] text-outline mt-1.5 text-center leading-relaxed">${items.length} producto(s) · ${totalUnits} unidades totales</p>`;
          finalizeSection.style.display = 'block';
        }
      }
      renderProducts();
    }

    // ── Finalize cotización ──
    (window as any).finalizeCotizacion = async function() {
      if (!currentSolicitudId) return;
      if (!confirm('¿Enviar cotización a los proveedores?\n\nEllos recibirán el detalle de productos y cantidades. El cliente será notificado que su solicitud está siendo cotizada.')) return;

      const notes = (document.getElementById('cart-notes') as HTMLTextAreaElement)?.value || '';
      const btn = document.getElementById('btn-finalize')!;
      btn.innerHTML = '<span class="material-symbols-outlined text-base animate-spin">progress_activity</span> Enviando...';
      (btn as any).disabled = true;

      try {
        const res = await fetch('/api/cotizaciones', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id_solicitud: currentSolicitudId,
            notas_operador: notes,
          }),
        });
        const json = await res.json();
        if (!res.ok) {
          alert(json.error || 'Error al finalizar');
          btn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Terminar Cotización';
          (btn as any).disabled = false;
          return;
        }

        // Update status in UI
        updateSolicitudStatus(currentSolicitudId!, 'cotizada');
        await loadCart();
        alert('✅ ' + (json.message || 'Cotización enviada exitosamente.'));
      } catch (e) {
        alert('Error de conexión');
        btn.innerHTML = '<span class="material-symbols-outlined text-base">send</span> Terminar Cotización';
        (btn as any).disabled = false;
      }
    };

    // removeFromCart still needed for cart items
    (window as any).removeFromCart = async function(cotizacionId: string) {
      try {
        const res = await fetch(`/api/cotizaciones?id_cotizacion=${cotizacionId}`, { method: 'DELETE' });
        if (!res.ok) { const j = await res.json(); alert(j.error || 'Error'); return; }
        await loadCart();
        if (cartProductIds.size === 0) {
          updateSolicitudStatus(currentSolicitudId!, 'pendiente');
        }
      } catch (e) { alert('Error de conexión'); }
    };

    // Update the status text in the left panel without reloading
    function updateSolicitudStatus(solId: string, newStatus: string) {
      const labels = document.querySelectorAll(`.sol-status-label[data-sol-id="${solId}"]`);
      labels.forEach(label => {
        label.textContent = newStatus;
        label.className = 'sol-status-label text-[10px] font-bold uppercase ' +
          (newStatus === 'pendiente' ? 'text-error' : newStatus === 'completada' ? 'text-outline' : 'text-secondary');
      });
      // Also update the detail badge
      const stBadge = document.getElementById('detail-status-badge')!;
      const stIcon = newStatus === 'pendiente' ? 'pending' : newStatus === 'cotizada' ? 'send' : newStatus === 'completada' ? 'check_circle' : 'autorenew';
      const stClass = newStatus === 'pendiente' ? 'bg-error-container/30 text-error' : newStatus === 'cotizada' ? 'bg-tertiary-container/30 text-tertiary' : newStatus === 'completada' ? 'bg-surface-container-highest text-on-surface-variant' : 'bg-secondary-container/30 text-secondary';
      stBadge.className = `px-3 py-1.5 rounded-full text-xs font-bold inline-flex items-center gap-1 ${stClass}`;
      stBadge.innerHTML = `<span class="material-symbols-outlined text-xs">${stIcon}</span>${newStatus}`;
      // Update the button data too
      const activeBtn = document.querySelector('.solicitud-item.bg-primary\\/5') as HTMLElement;
      if (activeBtn) activeBtn.dataset.status = newStatus;
    }

    // ── Solicitud selection ──
    const items = document.querySelectorAll('.solicitud-item');
    const emptyState = document.getElementById('empty-state')!;
    const detailPanel = document.getElementById('detail-panel')!;

    items.forEach((item) => {
      item.addEventListener('click', async () => {
        const el = item as HTMLElement;
        items.forEach(i => { (i as HTMLElement).classList.remove('bg-primary/5'); });
        el.classList.add('bg-primary/5');
        emptyState.style.display = 'none';
        detailPanel.style.display = 'flex';
        currentSolicitudId = el.dataset.id || null;
        currentDescription = el.dataset.desc || '';
        try { currentSpecs = JSON.parse(el.dataset.specs || '{}'); } catch { currentSpecs = {}; }

        const client = el.dataset.client || '—';
        document.getElementById('detail-avatar')!.textContent = client[0]?.toUpperCase() || '?';
        document.getElementById('detail-client')!.textContent = client;
        document.getElementById('detail-email')!.textContent = el.dataset.email || '—';
        document.getElementById('detail-desc')!.textContent = el.dataset.desc || '—';

        const smsBtn = document.getElementById('detail-sms-btn') as HTMLAnchorElement;
        if (el.dataset.phone) { smsBtn.href = `sms:${el.dataset.phone}`; smsBtn.style.display = 'inline-flex'; }
        else { smsBtn.style.display = 'none'; }

        const urgBadge = document.getElementById('detail-urgency-badge')!;
        const urg = (el.dataset.urgency || '').toLowerCase();
        urgBadge.textContent = el.dataset.urgency || '—';
        urgBadge.className = 'px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider ' +
          (urg === 'alta' ? 'bg-error/10 text-error' : urg === 'media' ? 'bg-tertiary/10 text-tertiary' : 'bg-outline/10 text-outline');

        const stBadge = document.getElementById('detail-status-badge')!;
        const st = (el.dataset.status || '').toLowerCase();
        const stIcon = st === 'pendiente' ? 'pending' : st === 'completada' ? 'check_circle' : 'autorenew';
        const stClass = st === 'pendiente' ? 'bg-error-container/30 text-error' : st === 'completada' ? 'bg-surface-container-highest text-on-surface-variant' : 'bg-secondary-container/30 text-secondary';
        stBadge.className = `px-3 py-1.5 rounded-full text-xs font-bold inline-flex items-center gap-1 ${stClass}`;
        stBadge.innerHTML = `<span class="material-symbols-outlined text-xs">${stIcon}</span>${el.dataset.status}`;

        const specsContainer = document.getElementById('detail-specs-container')!;
        const specsEl = document.getElementById('detail-specs')!;
        const entries = Object.entries(currentSpecs);
        if (entries.length > 0) {
          specsContainer.style.display = 'block';
          specsEl.innerHTML = entries.map(([key, val]) =>
            `<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-lg bg-surface-container-highest text-on-surface-variant text-xs"><strong class="text-on-surface">${key}:</strong> ${val}</span>`
          ).join('');
        } else { specsContainer.style.display = 'none'; }

        showMode = 'suggested';
        sortMode = 'relevance';
        updateModeButtons();
        updateSortButtons();
        // Clear search
        (document.getElementById('product-search') as HTMLInputElement).value = '';
        await loadCart();
      });
    });

    // ── Mode & Sort toggles ──
    function updateModeButtons() {
      document.getElementById('btn-show-suggested')!.className = 'mode-btn text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-lg ' +
        (showMode === 'suggested' ? 'bg-secondary/20 text-secondary' : 'bg-outline/10 text-outline hover:bg-outline/20 transition-colors');
      document.getElementById('btn-show-all')!.className = 'mode-btn text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-lg ' +
        (showMode === 'all' ? 'bg-secondary/20 text-secondary' : 'bg-outline/10 text-outline hover:bg-outline/20 transition-colors');
    }
    function updateSortButtons() {
      document.getElementById('btn-sort-rating')!.className = 'sort-btn text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-lg ' +
        (sortMode === 'rating' ? 'bg-amber-500/20 text-amber-600' : 'bg-outline/10 text-outline hover:bg-outline/20 transition-colors');
      document.getElementById('btn-sort-price')!.className = 'sort-btn text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-lg ' +
        (sortMode === 'price' ? 'bg-primary/20 text-primary' : 'bg-outline/10 text-outline hover:bg-outline/20 transition-colors');
    }

    document.getElementById('btn-show-suggested')?.addEventListener('click', () => { showMode = 'suggested'; updateModeButtons(); renderProducts(); });
    document.getElementById('btn-show-all')?.addEventListener('click', () => { showMode = 'all'; updateModeButtons(); renderProducts(); });
    document.getElementById('btn-sort-rating')?.addEventListener('click', () => { sortMode = sortMode === 'rating' ? 'relevance' : 'rating'; updateSortButtons(); renderProducts(); });
    document.getElementById('btn-sort-price')?.addEventListener('click', () => { sortMode = sortMode === 'price' ? 'relevance' : 'price'; updateSortButtons(); renderProducts(); });
    document.getElementById('product-search')?.addEventListener('input', () => renderProducts());

    // ── Product Modal ──
    let modalProductId: string | null = null;
    let modalPrice = 0;

    function closeProductModal() {
      document.getElementById('product-modal')!.style.display = 'none';
      document.body.style.overflow = '';
      modalProductId = null;
    }

    (window as any).openProductModal = function(productIndex: number) {
      const p = products[productIndex];
      if (!p) return;

      modalProductId = p.id_producto;
      modalPrice = p.precio_mayorista || 0;

      const modal = document.getElementById('product-modal')!;
      const icon = catIcons[(p.categoria || '').toLowerCase()] || 'category';
      const trust = p.mayoristas?.nivel_confianza || 0;
      const inCart = cartProductIds.has(p.id_producto);
      const reviews = p.ratings_productos || [];
      const avgRating = p._avgRating || 0;
      const totalReviews = p._totalReviews || 0;
      const moqNum = p.moq || 1;

      // Image
      const imgEl = document.getElementById('modal-img') as HTMLImageElement;
      const fallback = document.getElementById('modal-img-fallback')!;
      const iconEl = document.getElementById('modal-icon')!;
      if (p.imagen_url) {
        imgEl.src = p.imagen_url;
        imgEl.alt = p.nombre_articulo;
        imgEl.style.display = 'block';
        fallback.style.display = 'none';
        imgEl.onerror = () => { imgEl.style.display = 'none'; fallback.style.display = 'flex'; };
      } else {
        imgEl.style.display = 'none';
        fallback.style.display = 'flex';
        iconEl.textContent = icon;
      }

      // Text fields
      document.getElementById('modal-category')!.textContent = p.categoria || '—';
      document.getElementById('modal-name')!.textContent = p.nombre_articulo || '—';
      document.getElementById('modal-provider')!.innerHTML = `<span class="material-symbols-outlined text-sm">factory</span> ${p.mayoristas?.nombre_empresa || '—'} · ${p.mayoristas?.ubicacion || ''}`;
      document.getElementById('modal-trust-stars')!.innerHTML = renderStars(trust) + ` <span class="text-[10px] text-outline ml-1">(${trust}/5)</span>`;
      document.getElementById('modal-price')!.textContent = `$${modalPrice.toFixed(2)}`;
      document.getElementById('modal-moq')!.textContent = `MOQ: ${moqNum} unidades`;
      document.getElementById('modal-desc')!.textContent = p.descripcion || p.materiales || 'Sin descripción disponible.';

      // Materials
      const matSection = document.getElementById('modal-materials-section')!;
      if (p.materiales) {
        matSection.style.display = 'block';
        document.getElementById('modal-materials')!.textContent = p.materiales;
      } else {
        matSection.style.display = 'none';
      }

      // Reviews
      const ratingsSection = document.getElementById('modal-ratings-section')!;
      const reviewsEl = document.getElementById('modal-reviews')!;
      const avgBadge = document.getElementById('modal-avg-badge')!;

      if (reviews.length > 0) {
        ratingsSection.style.display = 'block';
        avgBadge.textContent = `${avgRating}★ (${totalReviews} reseña${totalReviews > 1 ? 's' : ''})`;
        reviewsEl.innerHTML = reviews.map((r: any) => `
          <div class="bg-surface-container-low rounded-xl p-3">
            <div class="flex items-center gap-2 mb-1">
              <span class="flex items-center gap-0.5">${renderStars(r.calificacion)}</span>
              <span class="text-[10px] text-outline font-bold">${r.calificacion}/5</span>
            </div>
            <p class="text-xs text-on-surface-variant leading-relaxed">"${r.comentario || ''}"</p>
          </div>
        `).join('');
      } else {
        ratingsSection.style.display = 'block';
        avgBadge.textContent = 'Sin reseñas';
        reviewsEl.innerHTML = '<p class="text-xs text-outline">Este producto aún no tiene reseñas de clientes.</p>';
      }

      // Quantity
      const qtyInput = document.getElementById('modal-qty') as HTMLInputElement;
      qtyInput.value = String(moqNum);
      updateModalSubtotal();

      // Cart state buttons
      const addBtn = document.getElementById('modal-add-btn')!;
      const removeBtn = document.getElementById('modal-remove-btn')!;
      if (inCart) {
        addBtn.style.display = 'none';
        removeBtn.style.display = 'flex';
      } else {
        addBtn.style.display = 'flex';
        removeBtn.style.display = 'none';
      }

      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    };

    function updateModalSubtotal() {
      const qty = parseInt((document.getElementById('modal-qty') as HTMLInputElement).value || '1');
      const subtotal = modalPrice * qty * 1.15;
      document.getElementById('modal-subtotal')!.textContent = `= $${subtotal.toLocaleString('en-US', { minimumFractionDigits: 2 })}`;
    }

    (window as any).changeQtyModal = function(delta: number) {
      const input = document.getElementById('modal-qty') as HTMLInputElement;
      const val = Math.max(1, parseInt(input.value || '1') + delta);
      input.value = String(val);
      updateModalSubtotal();
    };

    document.getElementById('modal-qty')?.addEventListener('input', updateModalSubtotal);

    (window as any).modalAddToCart = async function() {
      if (!currentSolicitudId || !modalProductId) return;
      const qty = parseInt((document.getElementById('modal-qty') as HTMLInputElement).value || '1');
      const totalPrice = modalPrice * qty * 1.15;
      const addBtn = document.getElementById('modal-add-btn')!;
      addBtn.innerHTML = '<span class="material-symbols-outlined text-base animate-spin">progress_activity</span> Agregando...';
      (addBtn as any).disabled = true;

      try {
        const res = await fetch('/api/cotizaciones', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id_solicitud: currentSolicitudId, id_producto: modalProductId, precio_final_cliente: totalPrice, costo_envio: 0, cantidad: qty }),
        });
        const json = await res.json();
        if (!res.ok) { alert(json.error || 'Error'); return; }
        updateSolicitudStatus(currentSolicitudId!, 'en proceso');
        await loadCart();
        // Update modal buttons
        addBtn.style.display = 'none';
        document.getElementById('modal-remove-btn')!.style.display = 'flex';
      } catch (e) { alert('Error de conexión'); }
      addBtn.innerHTML = '<span class="material-symbols-outlined text-base">add_shopping_cart</span> Agregar a Cotización';
      (addBtn as any).disabled = false;
    };

    (window as any).modalRemoveFromCart = async function() {
      if (!currentSolicitudId || !modalProductId) return;
      const res = await fetch(`/api/cotizaciones?id_solicitud=${currentSolicitudId}`);
      const json = await res.json();
      const item = (json.data || []).find((i: any) => i.id_producto === modalProductId);
      if (item) {
        const delRes = await fetch(`/api/cotizaciones?id_cotizacion=${item.id_cotizacion}`, { method: 'DELETE' });
        if (delRes.ok) {
          await loadCart();
          if (cartProductIds.size === 0) updateSolicitudStatus(currentSolicitudId!, 'pendiente');
          document.getElementById('modal-remove-btn')!.style.display = 'none';
          document.getElementById('modal-add-btn')!.style.display = 'flex';
        }
      }
    };

    // Close modal handlers
    document.getElementById('modal-close')?.addEventListener('click', closeProductModal);
    document.getElementById('modal-overlay')?.addEventListener('click', closeProductModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeProductModal(); });

    if (items.length > 0) (items[0] as HTMLElement).click();
  </script>
</DashboardLayout>

