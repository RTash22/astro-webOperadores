---

<DashboardLayout title="Carrito · Operadores">
  <div class="p-4 md:p-10 max-w-7xl mx-auto">

    <!-- Header -->
    <div class="mb-10">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <nav class="flex items-center gap-2 text-sm text-outline mb-4">
            <span>Marketplace</span>
            <span class="material-symbols-outlined text-xs">chevron_right</span>
            <span class="text-primary font-medium">Carrito</span>
          </nav>
          <h1 class="font-headline text-4xl font-extrabold text-on-surface tracking-tight">Carrito del Pedido</h1>
          <p class="text-on-surface-variant mt-2 max-w-2xl">Administra tus productos por mayorista antes de enviar la solicitud de cotización.</p>
        </div>
        <a
          href="/dashboard/marketplace"
          class="px-8 py-3 rounded-xl bg-surface-container-high text-primary font-semibold hover:bg-surface-container-highest transition-colors flex items-center gap-2 self-start md:self-auto"
        >
          <span class="material-symbols-outlined text-sm">arrow_back</span>
          Seguir Comprando
        </a>
      </div>
    </div>

    <!-- Wholesaler Sections -->
    <div class="space-y-8">
      {wholesalerOrders.map((order) => (
        <section class="bg-surface-container-low rounded-2xl p-6 md:p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class={`w-10 h-10 rounded-lg flex items-center justify-center ${order.iconBg}`}>
              <span class={`material-symbols-outlined ${order.iconColor}`}>{order.icon}</span>
            </div>
            <div>
              <h2 class="text-xl font-bold font-headline">Pedido: {order.wholesaler}</h2>
              <p class="text-xs text-on-surface-variant">ID Mayorista: {order.id}</p>
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-left border-separate border-spacing-y-3">
              <thead>
                <tr class="text-on-surface-variant text-sm font-medium uppercase tracking-wider">
                  <th class="px-4 pb-2">Producto</th>
                  <th class="px-4 pb-2">Precio</th>
                  <th class="px-4 pb-2">Cantidad</th>
                  <th class="px-4 pb-2">Estado</th>
                  <th class="px-4 pb-2 text-right">Subtotal</th>
                </tr>
              </thead>
              <tbody>
                {order.products.map((p) => (
                  <tr class="bg-surface-container-lowest hover:bg-surface-bright transition-all">
                    <td class="px-4 py-4 rounded-l-xl">
                      <div class="flex items-center gap-4">
                        <div class="w-16 h-16 rounded-lg bg-surface-container-high overflow-hidden flex-shrink-0">
                          <img src={p.imgSrc} alt={p.name} class="w-full h-full object-cover" />
                        </div>
                        <div>
                          <div class="font-bold text-on-surface">{p.name}</div>
                          <div class="text-xs text-on-surface-variant">{p.sku}</div>
                        </div>
                      </div>
                    </td>
                    <td class="px-4 py-4 font-headline font-semibold text-lg text-primary">{p.price}</td>
                    <td class="px-4 py-4">
                      <div class="flex items-center bg-surface-container-high rounded-full w-fit px-2">
                        <button class="p-1 text-primary hover:scale-110 transition-transform">
                          <span class="material-symbols-outlined">remove</span>
                        </button>
                        <input
                          type="text"
                          value={p.qty}
                          class="w-12 bg-transparent border-none text-center font-bold focus:ring-0"
                        />
                        <button class="p-1 text-primary hover:scale-110 transition-transform">
                          <span class="material-symbols-outlined">add</span>
                        </button>
                      </div>
                    </td>
                    <td class="px-4 py-4">
                      <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold ${p.statusClass}`}>
                        <span class="material-symbols-outlined text-xs">{p.statusIcon}</span>
                        {p.statusLabel}
                      </span>
                    </td>
                    <td class="px-4 py-4 text-right font-headline font-bold text-lg text-on-surface rounded-r-xl">{p.subtotal}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      ))}
    </div>

    <!-- Footer: Summary + Action -->
    <div class="mt-12 mb-10 flex flex-col md:flex-row gap-8 items-start md:items-stretch">

      <!-- Order Summary -->
      <div class="flex-1 p-8 rounded-2xl bg-primary text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -mr-20 -mt-20 blur-3xl"></div>
        <div class="relative z-10 flex flex-col h-full justify-between">
          <div>
            <h3 class="font-headline text-2xl font-bold mb-2">Resumen del Pedido</h3>
            <p class="text-blue-100/70 text-sm">Los gastos de envío se calcularán en el siguiente paso.</p>
          </div>
          <div class="mt-10 space-y-3">
            <div class="flex justify-between text-blue-100">
              <span>Subtotal (2 mayoristas)</span>
              <span class="font-semibold">$6,139.00</span>
            </div>
            <div class="flex justify-between text-blue-100">
              <span>Descuento corporativo</span>
              <span class="font-semibold text-secondary-fixed">-$150.00</span>
            </div>
            <div class="border-t border-white/10 pt-4 mt-4 flex justify-between items-end">
              <span class="text-lg">Total estimado</span>
              <span class="font-headline text-4xl font-extrabold tracking-tighter">$5,989.00</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Action -->
      <div class="w-full md:w-96 flex flex-col gap-4">
        <a
          href="/dashboard/carrito/detalles"
          class="w-full py-5 rounded-xl bg-gradient-to-br from-primary to-primary-container text-white font-extrabold text-lg shadow-xl shadow-primary/20 flex items-center justify-center gap-3 group hover:opacity-95 transition-opacity"
        >
          Continuar con los Detalles
          <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
        <div class="p-6 rounded-2xl bg-surface-container-high border border-outline-variant/15">
          <h4 class="font-bold mb-3 flex items-center gap-2">
            <span class="material-symbols-outlined text-tertiary">security</span>
            Compra Protegida
          </h4>
          <p class="text-xs text-on-surface-variant leading-relaxed">
            Su transacción está asegurada por el sistema Nexus Direct. Garantizamos la trazabilidad de cada pedido con los mayoristas.
          </p>
        </div>
      </div>

    </div>
  </div>
</DashboardLayout>
