---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Detalles del Pedido · Operadores">
  <div class="p-4 md:p-10 max-w-4xl mx-auto">

    <!-- Header -->
    <div class="mb-10">
      <nav class="flex items-center gap-2 text-sm text-outline mb-4">
        <a href="/dashboard/marketplace" class="hover:text-primary transition-colors">Marketplace</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <a href="/dashboard/carrito" class="hover:text-primary transition-colors">Carrito</a>
        <span class="material-symbols-outlined text-xs">chevron_right</span>
        <span class="text-primary font-medium">Detalles del Pedido</span>
      </nav>
      <h1 class="font-headline text-4xl font-extrabold text-on-surface tracking-tight">Detalles del Pedido</h1>
      <p class="text-on-surface-variant mt-2">Completa la información de tu empresa para enviar la solicitud de cotización al mayorista.</p>
    </div>

    <div class="space-y-6">

      <!-- Order Summary Card -->
      <div class="bg-surface-container-low rounded-2xl p-6 flex flex-col md:flex-row gap-6 items-start md:items-center justify-between">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center">
            <span class="material-symbols-outlined text-primary">shopping_cart</span>
          </div>
          <div>
            <p class="text-xs text-outline uppercase font-bold tracking-wider">Pedido en revisión</p>
            <p class="font-headline font-bold text-on-surface text-lg">2 mayoristas · 3 productos</p>
          </div>
        </div>
        <div class="text-right">
          <p class="text-xs text-outline uppercase font-bold tracking-wider">Total estimado</p>
          <p class="font-headline text-2xl font-extrabold text-primary">$5,989.00</p>
        </div>
      </div>

      <!-- Client Details Form -->
      <div class="bg-surface-container-lowest rounded-2xl p-6 md:p-8 border border-outline-variant/15">
        <h2 class="font-headline text-xl font-bold text-on-surface mb-6 flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">business</span>
          Información de la Empresa
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

          <!-- Nombre de la empresa -->
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant">Nombre de la empresa</label>
            <input
              type="text"
              placeholder="Ej. Distribuidora López S.A."
              class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:outline-none"
            />
          </div>

          <!-- RFC / Identificación fiscal -->
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant">RFC / ID Fiscal</label>
            <input
              type="text"
              placeholder="Ej. XAXX010101000"
              class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:outline-none"
            />
          </div>

          <!-- Nombre del contacto -->
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant">Nombre del contacto</label>
            <input
              type="text"
              placeholder="Ej. Juan Pérez"
              class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:outline-none"
            />
          </div>

          <!-- Teléfono -->
          <div class="flex flex-col gap-2">
            <label class="text-sm font-semibold text-on-surface-variant">Teléfono</label>
            <input
              type="tel"
              placeholder="Ej. +52 55 1234 5678"
              class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:outline-none"
            />
          </div>

          <!-- Correo electrónico -->
          <div class="flex flex-col gap-2 md:col-span-2">
            <label class="text-sm font-semibold text-on-surface-variant">Correo electrónico</label>
            <input
              type="email"
              placeholder="contacto@empresa.com"
              class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:outline-none"
            />
          </div>

          <!-- Dirección de entrega -->
          <div class="flex flex-col gap-2 md:col-span-2">
            <label class="text-sm font-semibold text-on-surface-variant">Dirección de entrega</label>
            <input
              type="text"
              placeholder="Calle, número, colonia, ciudad, C.P."
              class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:outline-none"
            />
          </div>

          <!-- Notas adicionales -->
          <div class="flex flex-col gap-2 md:col-span-2">
            <label class="text-sm font-semibold text-on-surface-variant">Notas adicionales <span class="text-outline font-normal">(opcional)</span></label>
            <textarea
              rows="3"
              placeholder="Instrucciones especiales de entrega, referencias, etc."
              class="w-full bg-surface-container-low border-none rounded-xl py-3 px-4 text-sm text-on-surface placeholder-outline focus:ring-2 focus:ring-primary/20 focus:outline-none resize-none"
            ></textarea>
          </div>

        </div>
      </div>

      <!-- Actions -->
      <div class="flex flex-col md:flex-row gap-4 items-center justify-between pt-2">
        <a
          href="/dashboard/carrito"
          class="flex items-center gap-2 text-sm font-semibold text-outline hover:text-on-surface transition-colors"
        >
          <span class="material-symbols-outlined text-sm">arrow_back</span>
          Volver al carrito
        </a>

        <a
          href="/dashboard/pedidos"
          class="px-10 py-4 rounded-xl bg-gradient-to-br from-primary to-primary-container text-white font-extrabold text-base shadow-lg shadow-primary/20 flex items-center gap-3 group hover:opacity-95 transition-opacity"
        >
          <span class="material-symbols-outlined">send</span>
          Enviar Solicitud al Mayorista
          <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
      </div>

    </div>
  </div>
</DashboardLayout>
