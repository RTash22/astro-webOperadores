---
const currentPath = Astro.url.pathname;
const navItems = [
  { icon: 'dashboard',       label: 'Dashboard',      href: '/dashboard'              },
  { icon: 'assignment',      label: 'Solicitudes',    href: '/dashboard/solicitudes'  },
  { icon: 'storefront',      label: 'Marketplace',    href: '/dashboard/marketplace'  },
  { icon: 'inventory_2',     label: 'Pedidos',        href: '/dashboard/pedidos'      },
  { icon: 'shopping_cart',   label: 'Carrito',        href: '/dashboard/carrito'      },
  { icon: 'settings',        label: 'Settings',       href: '#'                       },
  { icon: 'logout',          label: 'Cerrar Sesión',  href: '/'                       },
];
---

<aside class="h-screen w-64 fixed left-0 top-0 flex flex-col bg-[#f3f3f6] py-6 pl-4 z-50">
  <div class="mb-10 px-4">
    <h1 class="font-headline font-extrabold text-[#004d75] text-2xl tracking-tight">Coperativa</h1>
    <p class="text-xs font-medium text-[#44474e] uppercase tracking-widest mt-1">Operator Portal</p>
  </div>

  <nav class="flex-1 space-y-1 pr-4">
    {navItems.map((item) => {
      const isActive = currentPath === item.href || (item.href !== '/dashboard' && currentPath.startsWith(item.href));
      return isActive ? (
        <a
          href={item.href}
          class="flex items-center gap-3 px-4 py-3 bg-white text-[#004d75] rounded-l-xl font-semibold transition-all duration-200 ease-in-out"
        >
          <span class="material-symbols-outlined">{item.icon}</span>
          <span class="font-body text-sm">{item.label}</span>
        </a>
      ) : (
        <a
          href={item.href}
          class="flex items-center gap-3 px-4 py-3 text-[#44474e] hover:text-[#004d75] hover:bg-white/50 transition-all duration-200 ease-in-out"
        >
          <span class="material-symbols-outlined">{item.icon}</span>
          <span class="font-body text-sm">{item.label}</span>
        </a>
      );
    })}
  </nav>
</aside>

